script-source,101,node:internal/webidl,'use strict';\n\nconst {\n  ArrayPrototypePush\x2C\n  ArrayPrototypeToSorted\x2C\n  MathAbs\x2C\n  MathMax\x2C\n  MathMin\x2C\n  MathPow\x2C\n  MathSign\x2C\n  MathTrunc\x2C\n  NumberIsNaN\x2C\n  NumberMAX_SAFE_INTEGER\x2C\n  NumberMIN_SAFE_INTEGER\x2C\n  ObjectAssign\x2C\n  SafeSet\x2C\n  String\x2C\n  Symbol\x2C\n  SymbolIterator\x2C\n  TypeError\x2C\n} = primordials;\n\nconst {\n  codes: {\n    ERR_INVALID_ARG_VALUE\x2C\n  }\x2C\n} = require('internal/errors');\nconst { kEmptyObject } = require('internal/util');\n\nconst converters = { __proto__: null };\n\nconst UNDEFINED = Symbol('undefined');\nconst BOOLEAN = Symbol('boolean');\nconst STRING = Symbol('string');\nconst SYMBOL = Symbol('symbol');\nconst NUMBER = Symbol('number');\nconst BIGINT = Symbol('bigint');\nconst NULL = Symbol('null');\nconst OBJECT = Symbol('object');\n\n/**\n * @see https://webidl.spec.whatwg.org/#es-any\n * @param {any} V\n * @returns {any}\n */\nconverters.any = (V) => {\n  return V;\n};\n\nconverters.object = (V\x2C opts = kEmptyObject) => {\n  if (type(V) !== OBJECT) {\n    throw makeException(\n      'is not an object'\x2C\n      kEmptyObject\x2C\n    );\n  }\n  return V;\n};\n\n// https://webidl.spec.whatwg.org/#abstract-opdef-integerpart\nconst integerPart = MathTrunc;\n\n/* eslint-disable node-core/non-ascii-character */\n// Round x to the nearest integer\x2C choosing the even integer if it lies halfway\n// between two\x2C and choosing +0 rather than -0.\n// This is different from Math.round\x2C which rounds to the next integer in the\n// direction of +\u221e when the fraction portion is exactly 0.5.\n/* eslint-enable node-core/non-ascii-character */\nfunction evenRound(x) {\n  // Convert -0 to +0.\n  const i = integerPart(x) + 0;\n  const reminder = MathAbs(x % 1);\n  const sign = MathSign(i);\n  if (reminder === 0.5) {\n    return i % 2 === 0 ? i : i + sign;\n  }\n  const r = reminder < 0.5 ? i : i + sign;\n  // Convert -0 to +0.\n  if (r === 0) {\n    return 0;\n  }\n  return r;\n}\n\nfunction pow2(exponent) {\n  // << operates on 32 bit signed integers.\n  if (exponent < 31) {\n    return 1 << exponent;\n  }\n  if (exponent === 31) {\n    return 0x8000_0000;\n  }\n  if (exponent === 32) {\n    return 0x1_0000_0000;\n  }\n  return MathPow(2\x2C exponent);\n}\n\n// https://tc39.es/ecma262/#eqn-modulo\n// The notation \u201cx modulo y\u201d computes a value k of the same sign as y.\nfunction modulo(x\x2C y) {\n  const r = x % y;\n  // Convert -0 to +0.\n  if (r === 0) {\n    return 0;\n  }\n  return r;\n}\n\n// https://webidl.spec.whatwg.org/#abstract-opdef-converttoint\nfunction convertToInt(name\x2C value\x2C bitLength\x2C options = kEmptyObject) {\n  const { signed = false\x2C enforceRange = false\x2C clamp = false } = options;\n\n  let upperBound;\n  let lowerBound;\n  // 1. If bitLength is 64\x2C then:\n  if (bitLength === 64) {\n    // 1.1. Let upperBound be 2^53 \u2212 1.\n    upperBound = NumberMAX_SAFE_INTEGER;\n    // 1.2. If signedness is "unsigned"\x2C then let lowerBound be 0.\n    // 1.3. Otherwise let lowerBound be \u22122^53 + 1.\n    lowerBound = !signed ? 0 : NumberMIN_SAFE_INTEGER;\n  } else if (!signed) {\n    // 2. Otherwise\x2C if signedness is "unsigned"\x2C then:\n    // 2.1. Let lowerBound be 0.\n    // 2.2. Let upperBound be 2^bitLength \u2212 1.\n    lowerBound = 0;\n    upperBound = pow2(bitLength) - 1;\n  } else {\n    // 3. Otherwise:\n    // 3.1. Let lowerBound be -2^(bitLength \u2212 1).\n    // 3.2. Let upperBound be 2^(bitLength \u2212 1) \u2212 1.\n    lowerBound = -pow2(bitLength - 1);\n    upperBound = pow2(bitLength - 1) - 1;\n  }\n\n  // 4. Let x be ? ToNumber(V).\n  let x = +value;\n  // 5. If x is \u22120\x2C then set x to +0.\n  if (x === 0) {\n    x = 0;\n  }\n\n  // 6. If the conversion is to an IDL type associated with the [EnforceRange]\n  // extended attribute\x2C then:\n  if (enforceRange) {\n    // 6.1. If x is NaN\x2C +\u221e\x2C or \u2212\u221e\x2C then throw a TypeError.\n    if (NumberIsNaN(x) || x === Infinity || x === -Infinity) {\n      throw new ERR_INVALID_ARG_VALUE(name\x2C x);\n    }\n    // 6.2. Set x to IntegerPart(x).\n    x = integerPart(x);\n\n    // 6.3. If x < lowerBound or x > upperBound\x2C then throw a TypeError.\n    if (x < lowerBound || x > upperBound) {\n      throw new ERR_INVALID_ARG_VALUE(name\x2C x);\n    }\n\n    // 6.4. Return x.\n    return x;\n  }\n\n  // 7. If x is not NaN and the conversion is to an IDL type associated with\n  // the [Clamp] extended attribute\x2C then:\n  if (clamp && !NumberIsNaN(x)) {\n    // 7.1. Set x to min(max(x\x2C lowerBound)\x2C upperBound).\n    x = MathMin(MathMax(x\x2C lowerBound)\x2C upperBound);\n\n    // 7.2. Round x to the nearest integer\x2C choosing the even integer if it\n    // lies halfway between two\x2C and choosing +0 rather than \u22120.\n    x = evenRound(x);\n\n    // 7.3. Return x.\n    return x;\n  }\n\n  // 8. If x is NaN\x2C +0\x2C +\u221e\x2C or \u2212\u221e\x2C then return +0.\n  if (NumberIsNaN(x) || x === 0 || x === Infinity || x === -Infinity) {\n    return 0;\n  }\n\n  // 9. Set x to IntegerPart(x).\n  x = integerPart(x);\n\n  // 10. Set x to x modulo 2^bitLength.\n  x = modulo(x\x2C pow2(bitLength));\n\n  // 11. If signedness is "signed" and x \u2265 2^(bitLength \u2212 1)\x2C then return x \u2212\n  // 2^bitLength.\n  if (signed && x >= pow2(bitLength - 1)) {\n    return x - pow2(bitLength);\n  }\n\n  // 12. Otherwise\x2C return x.\n  return x;\n}\n\n/**\n * @see https://webidl.spec.whatwg.org/#es-DOMString\n * @param {any} V\n * @returns {string}\n */\nconverters.DOMString = function DOMString(V) {\n  if (typeof V === 'symbol') {\n    throw new ERR_INVALID_ARG_VALUE('value'\x2C V);\n  }\n\n  return String(V);\n};\n\nconverters['sequence<object>'] = createSequenceConverter(converters.object);\n\nfunction codedTypeError(message\x2C errorProperties = kEmptyObject) {\n  // eslint-disable-next-line no-restricted-syntax\n  const err = new TypeError(message);\n  ObjectAssign(err\x2C errorProperties);\n  return err;\n}\n\nfunction makeException(message\x2C opts = kEmptyObject) {\n  const prefix = opts.prefix ? opts.prefix + ': ' : '';\n  const context = opts.context?.length === 0 ?\n    '' : (opts.context ?? 'Value') + ' ';\n  return codedTypeError(\n    `${prefix}${context}${message}`\x2C\n    { code: opts.code || 'ERR_INVALID_ARG_TYPE' }\x2C\n  );\n}\n\nfunction createEnumConverter(name\x2C values) {\n  const E = new SafeSet(values);\n\n  return function(V\x2C opts = kEmptyObject) {\n    const S = String(V);\n\n    if (!E.has(S)) {\n      throw makeException(\n        `value '${S}' is not a valid enum value of type ${name}.`\x2C\n        { __proto__: null\x2C ...opts\x2C code: 'ERR_INVALID_ARG_VALUE' });\n    }\n\n    return S;\n  };\n}\n\n// https://tc39.es/ecma262/#sec-ecmascript-data-types-and-values\nfunction type(V) {\n  switch (typeof V) {\n    case 'undefined':\n      return UNDEFINED;\n    case 'boolean':\n      return BOOLEAN;\n    case 'number':\n      return NUMBER;\n    case 'string':\n      return STRING;\n    case 'symbol':\n      return SYMBOL;\n    case 'bigint':\n      return BIGINT;\n    case 'object': // Fall through\n    case 'function': // Fall through\n    default:\n      if (V === null) {\n        return NULL;\n      }\n      // Per ES spec\x2C typeof returns an implementation-defined value that is not\n      // any of the existing ones for uncallable non-standard exotic objects.\n      // Yet Type() which the Web IDL spec depends on returns Object for such\n      // cases. So treat the default case as an object.\n      return OBJECT;\n  }\n}\n\n// https://webidl.spec.whatwg.org/#js-dictionary\nfunction createDictionaryConverter(members) {\n  // The spec requires us to operate the members of a dictionary in\n  // lexicographical order. We are doing this in the outer scope to\n  // reduce the overhead that could happen in the returned function.\n  const sortedMembers = ArrayPrototypeToSorted(members\x2C (a\x2C b) => {\n    if (a.key === b.key) {\n      return 0;\n    }\n    return a.key < b.key ? -1 : 1;\n  });\n\n  return function(\n    V\x2C\n    opts = kEmptyObject\x2C\n  ) {\n    if (V != null && type(V) !== OBJECT) {\n      throw makeException(\n        'cannot be converted to a dictionary'\x2C\n        opts\x2C\n      );\n    }\n\n    const idlDict = { __proto__: null };\n    for (let i = 0; i < sortedMembers.length; i++) {\n      const member = sortedMembers[i];\n      const key = member.key;\n      let jsMemberValue;\n      if (V == null) {\n        jsMemberValue = undefined;\n      } else {\n        jsMemberValue = V[key];\n      }\n\n      if (jsMemberValue !== undefined) {\n        const memberContext = opts.context ? `${key} in ${opts.context}` : `${key}`;\n        const converter = member.converter;\n        const idlMemberValue = converter(\n          jsMemberValue\x2C\n          {\n            __proto__: null\x2C\n            prefix: opts.prefix\x2C\n            context: memberContext\x2C\n          }\x2C\n        );\n        idlDict[key] = idlMemberValue;\n      } else if (typeof member.defaultValue === 'function') {\n        const idlMemberValue = member.defaultValue();\n        idlDict[key] = idlMemberValue;\n      } else if (member.required) {\n        throw makeException(\n          `cannot be converted because of the missing '${key}'`\x2C\n          opts\x2C\n        );\n      }\n    }\n\n    return idlDict;\n  };\n}\n\n// https://webidl.spec.whatwg.org/#es-sequence\nfunction createSequenceConverter(converter) {\n  return function(V\x2C opts = kEmptyObject) {\n    if (type(V) !== OBJECT) {\n      throw makeException(\n        'can not be converted to sequence.'\x2C\n        opts);\n    }\n    const iter = V?.[SymbolIterator]?.();\n    if (iter === undefined) {\n      throw makeException(\n        'can not be converted to sequence.'\x2C\n        opts);\n    }\n    const array = [];\n    while (true) {\n      const res = iter?.next?.();\n      if (res === undefined) {\n        throw makeException(\n          'can not be converted to sequence.'\x2C\n          opts);\n      }\n      if (res.done === true) break;\n      const val = converter(res.value\x2C {\n        __proto__: null\x2C\n        ...opts\x2C\n        context: `${opts.context}\x2C index ${array.length}`\x2C\n      });\n      ArrayPrototypePush(array\x2C val);\n    };\n    return array;\n  };\n}\n\n\nmodule.exports = {\n  type\x2C\n  converters\x2C\n  convertToInt\x2C\n  createEnumConverter\x2C\n  createSequenceConverter\x2C\n  createDictionaryConverter\x2C\n  evenRound\x2C\n  makeException\x2C\n};\n
