script-source,168,node:worker_threads,'use strict';\n\nconst {\n  isInternalThread\x2C\n  isMainThread\x2C\n  SHARE_ENV\x2C\n  resourceLimits\x2C\n  setEnvironmentData\x2C\n  getEnvironmentData\x2C\n  threadId\x2C\n  threadName\x2C\n  Worker\x2C\n} = require('internal/worker');\n\nconst {\n  MessagePort\x2C\n  MessageChannel\x2C\n  markAsUncloneable\x2C\n  moveMessagePortToContext\x2C\n  receiveMessageOnPort\x2C\n  BroadcastChannel\x2C\n} = require('internal/worker/io');\n\nconst {\n  postMessageToThread\x2C\n} = require('internal/worker/messaging');\n\nconst {\n  markAsUntransferable\x2C\n  isMarkedAsUntransferable\x2C\n} = require('internal/buffer');\n\nmodule.exports = {\n  isInternalThread\x2C\n  isMainThread\x2C\n  MessagePort\x2C\n  MessageChannel\x2C\n  markAsUncloneable\x2C\n  markAsUntransferable\x2C\n  isMarkedAsUntransferable\x2C\n  moveMessagePortToContext\x2C\n  receiveMessageOnPort\x2C\n  resourceLimits\x2C\n  postMessageToThread\x2C\n  threadId\x2C\n  threadName\x2C\n  SHARE_ENV\x2C\n  Worker\x2C\n  parentPort: null\x2C\n  workerData: null\x2C\n  BroadcastChannel\x2C\n  setEnvironmentData\x2C\n  getEnvironmentData\x2C\n};\n
