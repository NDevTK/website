script-source,173,node:internal/modules/customization_hooks,'use strict';\n\nconst {\n  ArrayPrototypeFindIndex\x2C\n  ArrayPrototypePush\x2C\n  ArrayPrototypeSplice\x2C\n  ObjectAssign\x2C\n  ObjectFreeze\x2C\n  StringPrototypeSlice\x2C\n  StringPrototypeStartsWith\x2C\n  Symbol\x2C\n} = primordials;\nconst {\n  isAnyArrayBuffer\x2C\n  isArrayBufferView\x2C\n} = require('internal/util/types');\n\nconst { BuiltinModule } = require('internal/bootstrap/realm');\nconst {\n  ERR_INVALID_RETURN_PROPERTY_VALUE\x2C\n} = require('internal/errors').codes;\nconst { validateFunction } = require('internal/validators');\nconst { isAbsolute } = require('path');\nconst { pathToFileURL\x2C fileURLToPath } = require('internal/url');\n\nlet debug = require('internal/util/debuglog').debuglog('module_hooks'\x2C (fn) => {\n  debug = fn;\n});\n\n/**\n * @typedef {import('internal/modules/cjs/loader.js').Module} Module\n */\n/**\n * @typedef {(\n *   specifier: string\x2C\n *   context: Partial<ModuleResolveContext>\x2C\n * ) => ModuleResolveResult\n * } NextResolve\n * @typedef {(\n *   specifier: string\x2C\n *   context: ModuleResolveContext\x2C\n *   nextResolve: NextResolve\x2C\n * ) => ModuleResolveResult\n * } ResolveHook\n * @typedef {(\n *   url: string\x2C\n *   context: Partial<ModuleLoadContext>\x2C\n * ) => ModuleLoadResult\n * } NextLoad\n * @typedef {(\n *   url: string\x2C\n *   context: ModuleLoadContext\x2C\n *   nextLoad: NextLoad\x2C\n * ) => ModuleLoadResult\n * } LoadHook\n */\n\n// Use arrays for better insertion and iteration performance\x2C we don't care\n// about deletion performance as much.\n\n/** @type {ResolveHook[]} */\nconst resolveHooks = [];\n/** @type {LoadHook[]} */\nconst loadHooks = [];\nconst hookId = Symbol('kModuleHooksIdKey');\nlet nextHookId = 0;\n\nclass ModuleHooks {\n  /**\n   * @param {ResolveHook|undefined} resolve User-provided hook.\n   * @param {LoadHook|undefined} load User-provided hook.\n   */\n  constructor(resolve\x2C load) {\n    th