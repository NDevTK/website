script-source,174,node:internal/modules/package_json_reader,'use strict';\n\nconst {\n  ArrayIsArray\x2C\n  JSONParse\x2C\n  ObjectDefineProperty\x2C\n  RegExpPrototypeExec\x2C\n  SafeMap\x2C\n  StringPrototypeEndsWith\x2C\n  StringPrototypeIndexOf\x2C\n  StringPrototypeLastIndexOf\x2C\n  StringPrototypeSlice\x2C\n} = primordials;\nconst {\n  fileURLToPath\x2C\n  isURL\x2C\n  pathToFileURL\x2C\n  URL\x2C\n} = require('internal/url');\nconst { canParse: URLCanParse } = internalBinding('url');\nconst {\n  codes: {\n    ERR_INVALID_MODULE_SPECIFIER\x2C\n    ERR_MISSING_ARGS\x2C\n    ERR_MODULE_NOT_FOUND\x2C\n  }\x2C\n} = require('internal/errors');\nconst { kEmptyObject } = require('internal/util');\nconst modulesBinding = internalBinding('modules');\nconst path = require('path');\nconst permission = require('internal/process/permission');\nconst { validateString } = require('internal/validators');\nconst internalFsBinding = internalBinding('fs');\n\nconst nearestParentPackageJSONCache = new SafeMap();\n\n/**\n * @typedef {import('typings/internalBinding/modules').DeserializedPackageConfig} DeserializedPackageConfig\n * @typedef {import('typings/internalBinding/modules').PackageConfig} PackageConfig\n * @typedef {import('typings/internalBinding/modules').SerializedPackageConfig} SerializedPackageConfig\n */\n\n/**\n * @param {URL['pathname']} path\n * @param {SerializedPackageConfig} contents\n * @returns {DeserializedPackageConfig}\n */\nfunction deserializePackageJSON(path\x2C contents) {\n  if (contents === undefined) {\n    return {\n      data: {\n        __proto__: null\x2C\n        type: 'none'\x2C // Ignore unknown types for forwards compatibility\n      }\x2C\n      exists: false\x2C\n      path\x2C\n    };\n  }\n\n  const {\n    0: name\x2C\n    1: main\x2C\n    2: type\x2C\n    3: plainImports\x2C\n    4: plainExports\x2C\n    5: optionalFilePath\x2C\n  } = contents;\n\n  const pjsonPath = optionalFilePath ?? path;\n\n  return {\n    data: {\n      __proto__: null\x2C\n      ...(name != null && { name })\x2C\n      ...(main != null && { main })\x2C\n      ...(type != null && { type })\x2C\n      ...(plainImports != null && {\n        // This getters are used to lazily parse the imports and exports fields.\n        get imports() {\n          const value = requiresJSONParse(plainImports) ? JSONParse(plainImports) : plainImports;\n          ObjectDefineProperty(this\x2C 'imports'\x2C { __proto__: null\x2C value });\n          return this.imports;\n        }\x2C\n      })\x2C\n      ...(plainExports != null && {\n        get exports() {\n          const value = requiresJSONParse(plainExports) ? JSONParse(plainExports) : plainExports;\n          ObjectDefineProperty(this\x2C 'exports'\x2C { __proto__: null\x2C value });\n          return this.exports;\n        }\x2C\n      })\x2C\n    }\x2C\n    exists: true\x2C\n    path: pjsonPath\x2C\n  };\n}\n\n// The imports and exports fields can be either undefined or a string.\n// - If it's a string\x2C it's either plain string or a stringified JSON string.\n// - If it's a stringified JSON string\x2C it starts with either '[' or '{'.\nconst requiresJSONParse = (value) => (value !== undefined && (value[0] === '[' || value[0] === '{'));\n\n/**\n * Reads a package.json file and returns the parsed contents.\n * @param {string} jsonPath\n * @param {{\n *   base?: URL | string\x2C\n *   specifier?: URL | string\x2C\n *   isESM?: boolean\x2C\n * }} options\n * @returns {PackageConfig}\n */\nfunction read(jsonPath\x2C { base\x2C specifier\x2C isESM } = kEmptyObject) {\n  // This function will be called by both CJS and ESM\x2C so we need to make sure\n  // non-null attributes are converted to strings.\n  const parsed = modulesBinding.readPackageJSON(\n    jsonPath\x2C\n    isESM\x2C\n    base == null ? undefined : `${base}`\x2C\n    specifier == null ? undefined : `${specifier}`\x2C\n  );\n\n  const result = deserializePackageJSON(jsonPath\x2C parsed);\n\n  return {\n    __proto__: null\x2C\n    ...result.data\x2C\n    exists: result.exists\x2C\n    pjsonPath: result.path\x2C\n  };\n}\n\n/**\n * Given a file path\x2C walk the filesystem upwards until we find its closest parent\n * `package.json` file\x2C stopping when:\n * 1. we find a `package.json` file;\n * 2. we find a path that we do not have permission to read;\n * 3. we find a containing `node_modules` directory;\n * 4. or\x2C we reach the filesystem root\n * @returns {undefined | string}\n */\nfunction findParentPackageJSON(checkPath) {\n  const enabledPermission = permission.isEnabled();\n\n  const rootSeparatorIndex = StringPrototypeIndexOf(checkPath\x2C path.sep);\n  let separatorIndex;\n\n  do {\n    separatorIndex = StringPrototypeLastIndexOf(checkPath\x2C path.sep);\n    checkPath = StringPrototypeSlice(checkPath\x2C 0\x2C separatorIndex);\n\n    if (enabledPermission && !permission.has('fs.read'\x2C checkPath + path.sep)) {\n      return undefined;\n    }\n\n    if (StringPrototypeEndsWith(checkPath\x2C path.sep + 'node_modules')) {\n      return undefined;\n    }\n\n    const maybePackageJSONPath = checkPath + path.sep + 'package.json';\n    const stat = internalFsBinding.internalModuleStat(checkPath + path.sep + 'package.json');\n\n    const packageJSONExists = stat === 0;\n    if (packageJSONExists) {\n      return maybePackageJSONPath;\n    }\n  } while (separatorIndex > rootSeparatorIndex);\n\n  return undefined;\n}\n\n/**\n * Get the nearest parent package.json file from a given path.\n * Return the package.json data and the path to the package.json file\x2C or undefined.\n * @param {string} checkPath The path to start searching from.\n * @returns {undefined | DeserializedPackageConfig}\n */\nfunction getNearestParentPackageJSON(checkPath) {\n  const nearestParentPackageJSON = findParentPackageJSON(checkPath);\n\n  if (nearestParentPackageJSON === undefined) {\n    return undefined;\n  }\n\n  if (nearestParentPackageJSONCache.has(nearestParentPackageJSON)) {\n    return nearestParentPackageJSONCache.get(nearestParentPackageJSON);\n  }\n\n  const result = modulesBinding.readPackageJSON(nearestParentPackageJSON);\n\n  if (result === undefined) {\n    nearestParentPackageJSONCache.set(checkPath\x2C undefined);\n    return undefined;\n  }\n\n  const packageConfig = deserializePackageJSON(checkPath\x2C result);\n  nearestParentPackageJSONCache.set(nearestParentPackageJSON\x2C packageConfig);\n\n  return packageConfig;\n}\n\n/**\n * Returns the package configuration for the given resolved URL.\n * @param {URL | string} resolved - The resolved URL.\n * @returns {import('typings/internalBinding/modules').PackageConfig} - The package configuration.\n */\nfunction getPackageScopeConfig(resolved) {\n  const result = modulesBinding.getPackageScopeConfig(`${resolved}`);\n\n  if (ArrayIsArray(result)) {\n    const { data\x2C exists\x2C path } = deserializePackageJSON(`${resolved}`\x2C result);\n\n    return {\n      __proto__: null\x2C\n      ...data\x2C\n      exists\x2C\n      pjsonPath: path\x2C\n    };\n  }\n\n  // This means that the response is a string\n  // and it is the path to the package.json file\n  return {\n    __proto__: null\x2C\n    pjsonPath: result\x2C\n    exists: false\x2C\n    type: 'none'\x2C\n  };\n}\n\n/**\n * Returns the package type for a given URL.\n * @param {URL} url - The URL to get the package type for.\n */\nfunction getPackageType(url) {\n  const type = modulesBinding.getPackageType(`${url}`);\n  return type ?? 'none';\n}\n\nconst invalidPackageNameRegEx = /^\\.|%|\\\\/;\n/**\n * Parse a package name from a specifier.\n * @param {string} specifier - The import specifier.\n * @param {string | URL | undefined} base - The parent URL.\n */\nfunction parsePackageName(specifier\x2C base) {\n  let separatorIndex = StringPrototypeIndexOf(specifier\x2C '/');\n  let validPackageName = true;\n  let isScoped = false;\n  if (specifier[0] === '@') {\n    isScoped = true;\n    if (separatorIndex === -1 || specifier.length === 0) {\n      validPackageName = false;\n    } else {\n      separatorIndex = StringPrototypeIndexOf(\n        specifier\x2C '/'\x2C separatorIndex + 1);\n    }\n  }\n\n  const packageName = separatorIndex === -1 ?\n    specifier : StringPrototypeSlice(specifier\x2C 0\x2C separatorIndex);\n\n  // Package name cannot have leading . and cannot have percent-encoding or\n  // \\\\ separators.\n  if (RegExpPrototypeExec(invalidPackageNameRegEx\x2C packageName) !== null) {\n    validPackageName = false;\n  }\n\n  if (!validPackageName) {\n    throw new ERR_INVALID_MODULE_SPECIFIER(\n      specifier\x2C 'is not a valid package name'\x2C fileURLToPath(base));\n  }\n\n  const packageSubpath = '.' + (separatorIndex === -1 ? '' :\n    StringPrototypeSlice(specifier\x2C separatorIndex));\n\n  return { packageName\x2C packageSubpath\x2C isScoped };\n}\n\nfunction getPackageJSONURL(specifier\x2C base) {\n  const { packageName\x2C packageSubpath\x2C isScoped } = parsePackageName(specifier\x2C base);\n\n  // ResolveSelf\n  const packageConfig = getPackageScopeConfig(base);\n  if (packageConfig.exists) {\n    if (packageConfig.exports != null && packageConfig.name === packageName) {\n      const packageJSONPath = packageConfig.pjsonPath;\n      return { packageJSONUrl: pathToFileURL(packageJSONPath)\x2C packageJSONPath\x2C packageSubpath };\n    }\n  }\n\n  let packageJSONUrl = new URL(`./node_modules/${packageName}/package.json`\x2C base);\n  let packageJSONPath = fileURLToPath(packageJSONUrl);\n  let lastPath;\n  do {\n    const stat = internalFsBinding.internalModuleStat(\n      StringPrototypeSlice(packageJSONPath\x2C 0\x2C packageJSONPath.length - 13)\x2C\n    );\n    // Check for !stat.isDirectory()\n    if (stat !== 1) {\n      lastPath = packageJSONPath;\n      packageJSONUrl = new URL(\n        `${isScoped ? '../' : ''}../../../node_modules/${packageName}/package.json`\x2C\n        packageJSONUrl\x2C\n      );\n      packageJSONPath = fileURLToPath(packageJSONUrl);\n      continue;\n    }\n\n    // Package match.\n    return { packageJSONUrl\x2C packageJSONPath\x2C packageSubpath };\n  } while (packageJSONPath.length !== lastPath.length);\n\n  throw new ERR_MODULE_NOT_FOUND(packageName\x2C fileURLToPath(base)\x2C null);\n}\n\n/** @type {import('./esm/resolve.js').defaultResolve} */\nlet defaultResolve;\n/**\n * @param {URL['href'] | string | URL} specifier The location for which to get the "root" package.json\n * @param {URL['href'] | string | URL} [base] The location of the current module (ex file://tmp/foo.js).\n */\nfunction findPackageJSON(specifier\x2C base = 'data:') {\n  if (arguments.length === 0) {\n    throw new ERR_MISSING_ARGS('specifier');\n  }\n  try {\n    specifier = `${specifier}`;\n  } catch {\n    validateString(specifier\x2C 'specifier');\n  }\n\n  let parentURL = base;\n  if (!isURL(base)) {\n    validateString(base\x2C 'base');\n    parentURL = path.isAbsolute(base) ? pathToFileURL(base) : new URL(base);\n  }\n\n  if (specifier && specifier[0] !== '.' && specifier[0] !== '/' && !URLCanParse(specifier)) {\n    // If `specifier` is a bare specifier.\n    const { packageJSONPath } = getPackageJSONURL(specifier\x2C parentURL);\n    return packageJSONPath;\n  }\n\n  let resolvedTarget;\n  defaultResolve ??= require('internal/modules/esm/resolve').defaultResolve;\n\n  try {\n    // TODO(@JakobJingleheimer): Detect whether findPackageJSON is being used within a loader\n    // (possibly piggyback on `allowImportMetaResolve`)\n    // - When inside\x2C use the default resolve\n    //   - (I think it's impossible to use the chain because of re-entry & a deadlock from atomics).\n    // - When outside\x2C use cascadedLoader.resolveSync (not implemented yet\x2C but the pieces exist).\n    resolvedTarget = defaultResolve(specifier\x2C { parentURL: `${parentURL}` }).url;\n  } catch (err) {\n    if (err.code === 'ERR_UNSUPPORTED_DIR_IMPORT') {\n      resolvedTarget = err.url;\n    } else {\n      throw err;\n    }\n  }\n\n  const pkg = getNearestParentPackageJSON(fileURLToPath(resolvedTarget));\n\n  return pkg?.path;\n}\n\nmodule.exports = {\n  read\x2C\n  getNearestParentPackageJSON\x2C\n  getPackageScopeConfig\x2C\n  getPackageType\x2C\n  getPackageJSONURL\x2C\n  findPackageJSON\x2C\n};\n
