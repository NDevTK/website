script-source,109,node:internal/process/execution,'use strict';\n\nconst {\n  RegExpPrototypeExec\x2C\n  StringPrototypeIndexOf\x2C\n  StringPrototypeSlice\x2C\n  Symbol\x2C\n  globalThis\x2C\n} = primordials;\n\nconst path = require('path');\n\nconst {\n  codes: {\n    ERR_EVAL_ESM_CANNOT_PRINT\x2C\n    ERR_INVALID_ARG_TYPE\x2C\n    ERR_UNCAUGHT_EXCEPTION_CAPTURE_ALREADY_SET\x2C\n  }\x2C\n} = require('internal/errors');\nconst { pathToFileURL } = require('internal/url');\nconst { exitCodes: { kGenericUserError } } = internalBinding('errors');\nconst { stripTypeScriptModuleTypes } = require('internal/modules/typescript');\n\nconst {\n  executionAsyncId\x2C\n  clearDefaultTriggerAsyncId\x2C\n  clearAsyncIdStack\x2C\n  hasAsyncIdStack\x2C\n  afterHooksExist\x2C\n  emitAfter\x2C\n  popAsyncContext\x2C\n} = require('internal/async_hooks');\nconst { containsModuleSyntax } = internalBinding('contextify');\nconst { getOptionValue } = require('internal/options');\nconst {\n  makeContextifyScript\x2C runScriptInThisContext\x2C\n} = require('internal/vm');\n// shouldAbortOnUncaughtToggle is a typed array for faster\n// communication with JS.\nconst { shouldAbortOnUncaughtToggle } = internalBinding('util');\n\nconst kEvalTag = '[eval]';\n\nfunction tryGetCwd() {\n  try {\n    return process.cwd();\n  } catch {\n    // getcwd(3) can fail if the current working directory has been deleted.\n    // Fall back to the directory name of the (absolute) executable path.\n    // It's not really correct but what are the alternatives?\n    return path.dirname(process.execPath);\n  }\n}\n\nlet evalIndex = 0;\nfunction getEvalModuleUrl() {\n  return `${pathToFileURL(process.cwd())}/[eval${++evalIndex}]`;\n}\n\n/**\n * Evaluate an ESM entry point and return the promise that gets fulfilled after\n * it finishes evaluation.\n * @param {string} source Source code the ESM\n * @param {boolean} print Whether the result should be printed.\n * @returns {Promise}\n */\nfunction evalModuleEntryPoint(source\x2C print) {\n  if (print) {\n    throw new ERR_EVAL_ESM_CANNOT_PRINT();\n  }\n  RegExpPrototypeExec(/^/\x2C ''); // Necessary to reset RegExp statics before user code runs.\n  return require('internal/modules/run_main').runEntryPointWithESMLoader(\n    (loader) => loader.eval(source\x2C getEvalModuleUrl()\x2C true)\x2C\n  );\n}\n\nfunction evalScript(name\x2C body\x2C breakFirstLine\x2C print\x2C shouldLoadESM = false) {\n  const origModule = globalThis.module;  // Set e.g. when called from the REPL.\n  const module = createModule(name);\n  const baseUrl = pathToFileURL(module.filename).href;\n\n  if (shouldUseModuleEntryPoint(name\x2C body)) {\n    return getOptionValue('--experimental-strip-types') ?\n      evalTypeScriptModuleEntryPoint(body\x2C print) :\n      evalModuleEntryPoint(body\x2C print);\n  }\n\n  const evalFunction = () => runScriptInContext(name\x2C\n                                                body\x2C\n                                                breakFirstLine\x2C\n                                                print\x2C\n                                                module\x2C\n                                                baseUrl\x2C\n                                                undefined\x2C\n                                                origModule);\n\n  if (shouldLoadESM) {\n    return require('internal/modules/run_main').runEntryPointWithESMLoader(evalFunction);\n  }\n  evalFunction();\n}\n\nconst exceptionHandlerState = {\n  captureFn: null\x2C\n  reportFlag: false\x2C\n};\n\nfunction setUncaughtExceptionCaptureCallback(fn) {\n  if (fn === null) {\n    exceptionHandlerState.captureFn = fn;\n    shouldAbortOnUncaughtToggle[0] = 1;\n    process.report.reportOnUncaughtException = exceptionHandlerState.reportFlag;\n    return;\n  }\n  if (typeof fn !== 'function') {\n    throw new ERR_INVALID_ARG_TYPE('fn'\x2C ['Function'\x2C 'null']\x2C fn);\n  }\n  if (exceptionHandlerState.captureFn !== null) {\n    throw new ERR_UNCAUGHT_EXCEPTION_CAPTURE_ALREADY_SET();\n  }\n  exceptionHandlerState.captureFn = fn;\n  shouldAbortOnUncaughtToggle[0] = 0;\n  exceptionHandlerState.reportFlag =\n    process.report.reportOnUncaughtException === true;\n  process.report.reportOnUncaughtException = false;\n}\n\nfunction hasUncaughtExceptionCaptureCallback() {\n  return exceptionHandlerState.captureFn !== null;\n}\n\nfunction noop() {}\n\n// XXX(joyeecheung): for some reason this cannot be defined at the top-level\n// and exported to be written to process._fatalException\x2C it has to be\n// returned as an *anonymous function* wrapped inside a factory function\x2C\n// otherwise it breaks the test-timers.setInterval async hooks test -\n// this may indicate that node::errors::TriggerUncaughtException() should\n// fix up the callback scope before calling into process._fatalException\x2C\n// or this function should take extra care of the async hooks before it\n// schedules a setImmediate.\nfunction createOnGlobalUncaughtException() {\n  // The C++ land node::errors::TriggerUncaughtException() will\n  // exit the process if it returns false\x2C and continue execution if it\n  // returns true (which indicates that the exception is handled by the user).\n  return (er\x2C fromPromise) => {\n    // It's possible that defaultTriggerAsyncId was set for a constructor\n    // call that threw and was never cleared. So clear it now.\n    clearDefaultTriggerAsyncId();\n\n    const type = fromPromise ? 'unhandledRejection' : 'uncaughtException';\n    process.emit('uncaughtExceptionMonitor'\x2C er\x2C type);\n    if (exceptionHandlerState.captureFn !== null) {\n      exceptionHandlerState.captureFn(er);\n    } else if (!process.emit('uncaughtException'\x2C er\x2C type)) {\n      // If someone handled it\x2C then great. Otherwise\x2C die in C++ land\n      // since that means that we'll exit the process\x2C emit the 'exit' event.\n      try {\n        if (!process._exiting) {\n          process._exiting = true;\n          process.exitCode = kGenericUserError;\n          process.emit('exit'\x2C kGenericUserError);\n        }\n      } catch {\n        // Nothing to be done about it at this point.\n      }\n      return false;\n    }\n\n    // If we handled an error\x2C then make sure any ticks get processed\n    // by ensuring that the next Immediate cycle isn't empty.\n    require('timers').setImmediate(noop);\n\n    // Emit the after() hooks now that the exception has been handled.\n    if (afterHooksExist()) {\n      do {\n        const asyncId = executionAsyncId();\n        if (asyncId === 0)\n          popAsyncContext(0);\n        else\n          emitAfter(asyncId);\n      } while (hasAsyncIdStack());\n    }\n    // And completely empty the id stack\x2C including anything that may be\n    // cached on the native side.\n    clearAsyncIdStack();\n\n    return true;\n  };\n}\n\nfunction readStdin(callback) {\n  process.stdin.setEncoding('utf8');\n\n  let code = '';\n  process.stdin.on('data'\x2C (d) => {\n    code += d;\n  });\n\n  process.stdin.on('end'\x2C () => {\n    callback(code);\n  });\n}\n\n/**\n * Adds the TS message to the error stack.\n *\n * At the 3rd line of the stack\x2C the message is added.\n * @param {string} originalStack The stack to decorate\n * @param {string} newMessage the message to add to the error stack\n * @returns {void}\n */\nfunction decorateCJSErrorWithTSMessage(originalStack\x2C newMessage) {\n  let index;\n  for (let i = 0; i < 3; i++) {\n    index = StringPrototypeIndexOf(originalStack\x2C '\\n'\x2C index + 1);\n  }\n  return StringPrototypeSlice(originalStack\x2C 0\x2C index) +\n         '\\n' + newMessage +\n         StringPrototypeSlice(originalStack\x2C index);\n}\n\n/**\n *\n * Wrapper of evalScript\n *\n * This function wraps the evaluation of the source code in a try-catch block.\n * If the source code fails to be evaluated\x2C it will retry evaluating the source code\n * with the TypeScript parser.\n *\n * If the source code fails to be evaluated with the TypeScript parser\x2C\n * it will rethrow the original error\x2C adding the TypeScript error message to the stack.\n *\n * This way we don't change the behavior of the code\x2C but we provide a better error message\n * in case of a typescript error.\n * @param {string} name The name of the file\n * @param {string} source The source code to evaluate\n * @param {boolean} breakFirstLine Whether to break on the first line\n * @param {boolean} print If the result should be printed\n * @param {boolean} shouldLoadESM If the code should be loaded as an ESM module\n * @returns {void}\n */\nfunction evalTypeScript(name\x2C source\x2C breakFirstLine\x2C print\x2C shouldLoadESM = false) {\n  const origModule = globalThis.module;  // Set e.g. when called from the REPL.\n  const module = createModule(name);\n  const baseUrl = pathToFileURL(module.filename).href;\n\n  if (shouldUseModuleEntryPoint(name\x2C source)) {\n    return evalTypeScriptModuleEntryPoint(source\x2C print);\n  }\n\n  let compiledScript;\n  // This variable can be modified if the source code is stripped.\n  let sourceToRun = source;\n  try {\n    compiledScript = compileScript(name\x2C source\x2C baseUrl);\n  } catch (originalError) {\n    try {\n      sourceToRun = stripTypeScriptModuleTypes(source\x2C kEvalTag);\n      // Retry the CJS/ESM syntax detection after stripping the types.\n      if (shouldUseModuleEntryPoint(name\x2C sourceToRun)) {\n        return evalTypeScriptModuleEntryPoint(source\x2C print);\n      }\n      // If the ContextifiedScript was successfully created\x2C execute it.\n      // outside the try-catch block to avoid catching runtime errors.\n      compiledScript = compileScript(name\x2C sourceToRun\x2C baseUrl);\n    } catch (tsError) {\n      // If it's invalid or unsupported TypeScript syntax\x2C rethrow the original error\n      // with the TypeScript error message added to the stack.\n      if (tsError.code === 'ERR_INVALID_TYPESCRIPT_SYNTAX' || tsError.code === 'ERR_UNSUPPORTED_TYPESCRIPT_SYNTAX') {\n        originalError.stack = decorateCJSErrorWithTSMessage(originalError.stack\x2C tsError.message);\n        throw originalError;\n      }\n\n      throw tsError;\n    }\n  }\n\n  const evalFunction = () => runScriptInContext(name\x2C\n                                                sourceToRun\x2C\n                                                breakFirstLine\x2C\n                                                print\x2C\n                                                module\x2C\n                                                baseUrl\x2C\n                                                compiledScript\x2C\n                                                origModule);\n\n  if (shouldLoadESM) {\n    return require('internal/modules/run_main').runEntryPointWithESMLoader(evalFunction);\n  }\n  evalFunction();\n}\n\n/**\n * Wrapper of evalModuleEntryPoint\n *\n * This function wraps the compilation of the source code in a try-catch block.\n * If the source code fails to be compiled\x2C it will retry transpiling the source code\n * with the TypeScript parser.\n * @param {string} source The source code to evaluate\n * @param {boolean} print If the result should be printed\n * @returns {Promise} The module evaluation promise\n */\nfunction evalTypeScriptModuleEntryPoint(source\x2C print) {\n  if (print) {\n    throw new ERR_EVAL_ESM_CANNOT_PRINT();\n  }\n\n  RegExpPrototypeExec(/^/\x2C ''); // Necessary to reset RegExp statics before user code runs.\n\n  return require('internal/modules/run_main').runEntryPointWithESMLoader(\n    async (loader) => {\n      const url = getEvalModuleUrl();\n      let moduleWrap;\n      try {\n        // Compile the module to check for syntax errors.\n        moduleWrap = loader.createModuleWrap(source\x2C url);\n      } catch (originalError) {\n        try {\n          const strippedSource = stripTypeScriptModuleTypes(source\x2C kEvalTag);\n          // If the moduleWrap was successfully created\x2C execute the module job.\n          // outside the try-catch block to avoid catching runtime errors.\n          moduleWrap = loader.createModuleWrap(strippedSource\x2C url);\n        } catch (tsError) {\n          // If it's invalid or unsupported TypeScript syntax\x2C rethrow the original error\n          // with the TypeScript error message added to the stack.\n          if (tsError.code === 'ERR_INVALID_TYPESCRIPT_SYNTAX' ||\n            tsError.code === 'ERR_UNSUPPORTED_TYPESCRIPT_SYNTAX') {\n            originalError.stack = `${tsError.message}\\n\\n${originalError.stack}`;\n            throw originalError;\n          }\n\n          throw tsError;\n        }\n      }\n      // If the moduleWrap was successfully created either with by just compiling\n      // or after transpilation\x2C execute the module job.\n      return loader.executeModuleJob(url\x2C moduleWrap\x2C true);\n    }\x2C\n  );\n};\n\n/**\n *\n * Function used to shortcut when `--input-type=module-typescript` is set.\n * @param {string} source\n * @param {boolean} print\n */\nfunction parseAndEvalModuleTypeScript(source\x2C print) {\n  // We know its a TypeScript module\x2C we can safely emit the experimental warning.\n  const strippedSource = stripTypeScriptModuleTypes(source\x2C kEvalTag);\n  evalModuleEntryPoint(strippedSource\x2C print);\n}\n\n/**\n * Function used to shortcut when `--input-type=commonjs-typescript` is set\n * @param {string} name The name of the file\n * @param {string} source The source code to evaluate\n * @param {boolean} breakFirstLine Whether to break on the first line\n * @param {boolean} print If the result should be printed\n * @param {boolean} shouldLoadESM If the code should be loaded as an ESM module\n * @returns {void}\n */\nfunction parseAndEvalCommonjsTypeScript(name\x2C source\x2C breakFirstLine\x2C print\x2C shouldLoadESM = false) {\n  // We know its a TypeScript module\x2C we can safely emit the experimental warning.\n  const strippedSource = stripTypeScriptModuleTypes(source\x2C kEvalTag);\n  evalScript(name\x2C strippedSource\x2C breakFirstLine\x2C print\x2C shouldLoadESM);\n}\n\n/**\n *\n * @param {string} name - The filename of the script.\n * @param {string} body - The code of the script.\n * @param {string} baseUrl Path of the parent importing the module.\n * @returns {ContextifyScript} The created contextify script.\n */\nfunction compileScript(name\x2C body\x2C baseUrl) {\n  const hostDefinedOptionId = Symbol(name);\n  async function importModuleDynamically(specifier\x2C _\x2C importAttributes) {\n    const cascadedLoader = require('internal/modules/esm/loader').getOrInitializeCascadedLoader();\n    return cascadedLoader.import(specifier\x2C baseUrl\x2C importAttributes);\n  }\n  return makeContextifyScript(\n    body\x2C                    // code\n    name\x2C                    // filename\x2C\n    0\x2C                       // lineOffset\n    0\x2C                       // columnOffset\x2C\n    undefined\x2C               // cachedData\n    false\x2C                   // produceCachedData\n    undefined\x2C               // parsingContext\n    hostDefinedOptionId\x2C     // hostDefinedOptionId\n    importModuleDynamically\x2C // importModuleDynamically\n  );\n}\n\n/**\n * @param {string} name - The filename of the script.\n * @param {string} body - The code of the script.\n * @returns {boolean} Whether the module entry point should be evaluated as a module.\n */\nfunction shouldUseModuleEntryPoint(name\x2C body) {\n  return getOptionValue('--experimental-detect-module') && getOptionValue('--experimental-default-type') === '' &&\n    getOptionValue('--input-type') === '' &&\n    containsModuleSyntax(body\x2C name\x2C null\x2C 'no CJS variables');\n}\n\n/**\n *\n * @param {string} name - The filename of the script.\n * @returns {import('internal/modules/esm/loader').CJSModule} The created module.\n */\nfunction createModule(name) {\n  const CJSModule = require('internal/modules/cjs/loader').Module;\n  const cwd = tryGetCwd();\n  const module = new CJSModule(name);\n  module.filename = path.join(cwd\x2C name);\n  module.paths = CJSModule._nodeModulePaths(cwd);\n  return module;\n}\n\n/**\n *\n * @param {string} name - The filename of the script.\n * @param {string} body - The code of the script.\n * @param {boolean} breakFirstLine Whether to break on the first line\n * @param {boolean} print If the result should be printed\n * @param {import('internal/modules/esm/loader').CJSModule} module The module\n * @param {string} baseUrl Path of the parent importing the module.\n * @param {object} compiledScript The compiled script.\n * @param {any} origModule The original module.\n * @returns {void}\n */\nfunction runScriptInContext(name\x2C body\x2C breakFirstLine\x2C print\x2C module\x2C baseUrl\x2C compiledScript\x2C origModule) {\n  // Create wrapper for cache entry\n  const script = `\n      globalThis.module = module;\n      globalThis.exports = exports;\n      globalThis.__dirname = __dirname;\n      globalThis.require = require;\n      return (main) => main();\n    `;\n  globalThis.__filename = name;\n  RegExpPrototypeExec(/^/\x2C ''); // Necessary to reset RegExp statics before user code runs.\n  const result = module._compile(script\x2C `${name}-wrapper`)(() => {\n    // If the script was already compiled\x2C use it.\n    return runScriptInThisContext(\n      compiledScript ?? compileScript(name\x2C body\x2C baseUrl)\x2C\n      true\x2C !!breakFirstLine);\n  });\n  if (print) {\n    const { log } = require('internal/console/global');\n\n    process.on('exit'\x2C () => {\n      log(result);\n    });\n  }\n  if (origModule !== undefined)\n    globalThis.module = origModule;\n}\n\nmodule.exports = {\n  parseAndEvalCommonjsTypeScript\x2C\n  parseAndEvalModuleTypeScript\x2C\n  readStdin\x2C\n  tryGetCwd\x2C\n  evalModuleEntryPoint\x2C\n  evalTypeScript\x2C\n  evalScript\x2C\n  onGlobalUncaughtException: createOnGlobalUncaughtException()\x2C\n  setUncaughtExceptionCaptureCallback\x2C\n  hasUncaughtExceptionCaptureCallback\x2C\n};\n
